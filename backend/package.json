{
  "name": "almyty-backend",
  "version": "1.0.0",
  "description": "almyty Backend - Universal API to AI Tool Gateway System",
  "author": "frane",
  "private": true,
  "license": "BSL-1.1",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:db": "RUN_DB_INTEGRATION=1 jest src/test/integration",
    "test:e2e:staging": "npx tsx test/e2e/agent-runtime.e2e.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "typeorm:migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/config/database.config.ts",
    "typeorm:migration:run": "typeorm-ts-node-commonjs migration:run -d src/config/database.config.ts",
    "typeorm:migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/config/database.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@apidevtools/swagger-parser": "^10.1.1",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@nestjs-modules/ioredis": "^2.2.1",
    "@nestjs/bull": "^10.2.3",
    "@nestjs/cache-manager": "^2.3.0",
    "@nestjs/common": "^10.4.22",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.22",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/terminus": "^10.3.0",
    "@nestjs/throttler": "^5.2.0",
    "@nestjs/typeorm": "^10.0.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@types/bcrypt": "^6.0.0",
    "@types/bull": "^3.15.9",
    "@types/ws": "^8.18.1",
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "cache-manager": "^5.7.6",
    "cache-manager-redis-store": "^3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express-rate-limit": "^7.5.1",
    "graphql": "^16.13.2",
    "graphql-request": "^7.4.0",
    "graphql-tools": "^9.0.26",
    "helmet": "^7.2.0",
    "js2xmlparser": "^5.0.0",
    "jsonschema": "^1.5.0",
    "openai": "^4.104.0",
    "openapi-types": "^12.1.3",
    "passport": "^0.7.0",
    "passport-custom": "^1.1.1",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "protobufjs": "^7.5.4",
    "redis": "^4.7.1",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.10.0",
    "rxjs": "^7.8.2",
    "soap": "^1.8.0",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "typeorm-versions": "^0.5.1",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "ws": "^8.20.0",
    "xml2js": "^0.6.2"
  },
  "overrides": {
    "tar": "^7.5.11",
    "tar-fs": "^3.1.1",
    "cacache": "^18.0.5",
    "lodash": "^4.17.24",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.22",
    "@types/bcryptjs": "^2.4.6",
    "@types/cache-manager": "^4.0.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.37",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.8",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.module.ts",
      "!**/*.interface.ts",
      "!**/*.dto.ts",
      "!**/main.ts",
      "!**/migrations/**",
      "!**/temp-coverage/**"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/test/setup.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
