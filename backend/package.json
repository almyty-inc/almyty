{
  "name": "almyty-backend",
  "version": "1.0.0",
  "description": "almyty backend — open platform for building, deploying, and running AI agents",
  "author": "frane <frane.bandov@gmail.com>",
  "private": true,
  "license": "BSL-1.1",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:full": "RUN_DB_INTEGRATION=1 DATABASE_PORT=5433 DATABASE_PASSWORD=postgres DATABASE_NAME=almyty REDIS_PORT=6380 jest --forceExit",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:db": "RUN_DB_INTEGRATION=1 jest src/test/integration",
    "test:e2e:staging": "npx tsx test/e2e/agent-runtime.e2e.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "typeorm:migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/config/database.config.ts",
    "typeorm:migration:run": "typeorm-ts-node-commonjs migration:run -d src/config/database.config.ts",
    "typeorm:migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/config/database.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.0",
    "@apidevtools/swagger-parser": "^12.1.0",
    "@getzep/zep-cloud": "^3.18.0",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.0",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs-modules/ioredis": "^2.2.1",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "@radix-ui/react-switch": "^1.2.6",
    "@types/bcrypt": "^6.0.0",
    "@types/bull": "^4.10.4",
    "@types/node-fetch": "^2.6.13",
    "@types/stream-json": "^1.7.8",
    "@types/ws": "^8.18.1",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-store": "^3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express-rate-limit": "^8.4.1",
    "google-auth-library": "^10.6.2",
    "google-proto-files": "^5.0.1",
    "graphql": "^16.13.2",
    "graphql-request": "^7.4.0",
    "graphql-tools": "^9.0.28",
    "helmet": "^8.1.0",
    "js2xmlparser": "^5.0.0",
    "jsonschema": "^1.5.0",
    "mem0ai": "^3.0.2",
    "node-fetch": "^3.3.2",
    "openai": "^6.34.0",
    "openapi-types": "^12.1.3",
    "passport": "^0.7.0",
    "passport-custom": "^1.1.1",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.20.0",
    "pgvector": "^0.2.1",
    "prom-client": "^15.1.3",
    "protobufjs": "^8.6.3",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.1",
    "rxjs": "^7.8.2",
    "soap": "^1.9.1",
    "stream-json": "^2.1.0",
    "supermemory": "^4.21.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "typeorm-versions": "^0.6.0",
    "typescript": "^6.0.3",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "ws": "^8.20.0",
    "xml2js": "^0.6.2"
  },
  "overrides": {
    "tar": "^7.5.11",
    "tar-fs": "^3.1.1",
    "cacache": "^18.0.5",
    "lodash": "^4.17.24",
    "multer": "^2.1.1",
    "mem0ai": {
      "axios": "^1.16.0",
      "@qdrant/js-client-rest": {
        "undici": "^6.24.0"
      }
    },
    "google-proto-files": {
      "protobufjs": "^7.5.5"
    }
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typeorm-ts-node-commonjs": "^0.3.20"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(uuid)/)"
    ],
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.module.ts",
      "!**/*.interface.ts",
      "!**/*.dto.ts",
      "!**/main.ts",
      "!**/migrations/**",
      "!**/temp-coverage/**"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/test/setup.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
