import { Test, TestingModule } from '@nestjs/testing';
import { getRepositoryToken } from '@nestjs/typeorm';
import { NotFoundException, BadRequestException, ForbiddenException } from '@nestjs/common';
import axios from 'axios';

import { A2AService } from './a2a.service';
import { Tool } from '../../entities/tool.entity';
import { Organization } from '../../entities/organization.entity';
import { User } from '../../entities/user.entity';
import { McpSessionService } from './mcp-session.service';
import { ToolExecutorService } from '../tools/tool-executor.service';
import {
  A2AAgent,
  A2AAgentType,
  A2AMessage,
  A2AMessageType,
  A2ASession,
  A2ASessionStatus,
  A2AToolRegistration,
  A2AMetrics,
} from './types/a2a.types';

// Mock axios
jest.mock('axios', () => jest.fn());
const mockedAxios = axios as unknown as jest.Mock;

describe('A2AService', () => {
  let service: A2AService;
  let mockRedis: any;
  let organizationRepository: any;
  let userRepository: any;
  let toolRepository: any;
  let mcpSessionService: any;
  let toolExecutorService: any;

  beforeEach(async () => {
    mockRedis = {
      get: jest.fn(),
      set: jest.fn(),
      setex: jest.fn(),
      del: jest.fn(),
      hget: jest.fn(),
      hset: jest.fn(),
      keys: jest.fn(),
      llen: jest.fn(),
      lpush: jest.fn(),
      ltrim: jest.fn(),
    };

    const module: TestingModule = await Test.createTestingModule({
      providers: [
        A2AService,
        {
          provide: getRepositoryToken(Tool),
          useValue: {
            find: jest.fn(),
            findOne: jest.fn(),
            create: jest.fn(),
            save: jest.fn(),
          },
        },
        {
          provide: getRepositoryToken(Organization),
          useValue: {
            findOne: jest.fn(),
          },
        },
        {
          provide: getRepositoryToken(User),
          useValue: {
            findOne: jest.fn(),
          },
        },
        {
          provide: McpSessionService,
          useValue: {
            createSession: jest.fn(),
          },
        },
        {
          provide: ToolExecutorService,
          useValue: {
            executeTool: jest.fn(),
          },
        },
        {
          provide: 'default_IORedisModuleConnectionToken',
          useValue: mockRedis,
        },
      ],
    }).compile();

    service = module.get<A2AService>(A2AService);
    organizationRepository = module.get(getRepositoryToken(Organization));
    userRepository = module.get(getRepositoryToken(User));
    toolRepository = module.get(getRepositoryToken(Tool));
    mcpSessionService = module.get(McpSessionService);
    toolExecutorService = module.get(ToolExecutorService);
  });

  afterEach(() => {
    jest.clearAllMocks();
  });

  describe('Agent Registration and Management', () => {
    const mockOrganization = {
      id: 'org-1',
      name: 'Test Organization',
    };

    const mockAgentData = {
      name: 'Test Agent',
      description: 'A test agent',
      type: A2AAgentType.OPENAI,
      endpoint: 'https://api.test-agent.com',
      capabilities: {
        protocols: ['http'],
        messageFormats: ['json'],
        functions: {
          calling: true,
          streaming: false,
          chaining: false,
          parallel: false,
        },
        memory: {
          persistent: false,
          contextWindow: 4096,
          retrieval: false,
        },
      },
      configuration: {
        baseUrl: 'https://api.test-agent.com',
        timeout: 30000,
        retries: 3,
      },
      authentication: {
        type: 'api_key' as const,
        config: { apiKey: 'test-key' },
        location: 'header' as const,
        parameter: 'Authorization',
      },
      metadata: { version: '1.0.0' },
    };

    describe('registerAgent', () => {
      it('should register agent successfully', async () => {
        organizationRepository.findOne.mockResolvedValue(mockOrganization);
        mockedAxios.mockResolvedValue({ status: 200, data: {} });
        mockRedis.setex.mockResolvedValue('OK');

        const result = await service.registerAgent('org-1', mockAgentData);

        expect(result).toBeDefined();
        expect(result.name).toBe('Test Agent');
        expect(result.type).toBe(A2AAgentType.OPENAI);
        expect(result.organizationId).toBe('org-1');
        expect(result.isActive).toBe(true);
        expect(organizationRepository.findOne).toHaveBeenCalledWith({
          where: { id: 'org-1' },
        });
        expect(mockRedis.setex).toHaveBeenCalled();
      });

      it('should throw NotFoundException for invalid organization', async () => {
        organizationRepository.findOne.mockResolvedValue(null);

        await expect(
          service.registerAgent('org-1', mockAgentData)
        ).rejects.toThrow(NotFoundException);
      });

      it('should throw BadRequestException for unreachable endpoint', async () => {
        organizationRepository.findOne.mockResolvedValue(mockOrganization);
        mockedAxios.mockRejectedValue(new Error('Connection failed'));

        await expect(
          service.registerAgent('org-1', mockAgentData)
        ).rejects.toThrow(BadRequestException);
      });

      it('should set default capabilities for different agent types', async () => {
        organizationRepository.findOne.mockResolvedValue(mockOrganization);
        mockedAxios.mockResolvedValue({ status: 200, data: {} });
        mockRedis.setex.mockResolvedValue('OK');

        const anthropicAgentData = {
          ...mockAgentData,
          type: A2AAgentType.ANTHROPIC,
          capabilities: undefined,
        };

        const result = await service.registerAgent('org-1', anthropicAgentData);

        expect(result.capabilities.memory.contextWindow).toBe(200000);
        expect(result.capabilities.specializations).toContain('reasoning');
      });
    });

    describe('getAgent', () => {
      const mockAgent: A2AAgent = {
        id: 'agent-1',
        name: 'Test Agent',
        type: A2AAgentType.OPENAI,
        organizationId: 'org-1',
        endpoint: 'https://api.test.com',
        capabilities: {
          protocols: ['http'],
          messageFormats: ['json'],
          functions: {
            calling: true,
            streaming: false,
            chaining: false,
            parallel: false,
          },
          memory: {
            persistent: false,
            contextWindow: 4096,
            retrieval: false,
          },
        },
        configuration: {
          baseUrl: 'https://api.test.com',
          timeout: 30000,
          retries: 3,
        },
        isActive: true,
        lastSeen: new Date(),
      };

      it('should return agent from memory cache', async () => {
        // Manually add agent to service's internal map
        service['agents'].set('agent-1', mockAgent);

        const result = await service.getAgent('agent-1');

        expect(result).toEqual(mockAgent);
      });

      it('should return agent from Redis cache', async () => {
        mockRedis.get.mockResolvedValue(JSON.stringify(mockAgent));

        const result = await service.getAgent('agent-1');

        expect(result).toEqual(mockAgent);
        expect(mockRedis.get).toHaveBeenCalledWith('agent:agent-1');
      });

      it('should return null for non-existent agent', async () => {
        mockRedis.get.mockResolvedValue(null);

        const result = await service.getAgent('non-existent');

        expect(result).toBeNull();
      });

      it('should handle Redis errors gracefully', async () => {
        mockRedis.get.mockRejectedValue(new Error('Redis error'));

        const result = await service.getAgent('agent-1');

        expect(result).toBeNull();
      });
    });

    describe('listAgents', () => {
      it('should return agents for organization', async () => {
        const agent1: A2AAgent = {
          id: 'agent-1',
          organizationId: 'org-1',
          isActive: true,
        } as A2AAgent;

        const agent2: A2AAgent = {
          id: 'agent-2',
          organizationId: 'org-1',
          isActive: true,
        } as A2AAgent;

        const agent3: A2AAgent = {
          id: 'agent-3',
          organizationId: 'org-2',
          isActive: true,
        } as A2AAgent;

        service['agents'].set('agent-1', agent1);
        service['agents'].set('agent-2', agent2);
        service['agents'].set('agent-3', agent3);

        const result = await service.listAgents('org-1');

        expect(result).toHaveLength(2);
        expect(result.map(a => a.id)).toEqual(['agent-1', 'agent-2']);
      });

      it('should filter out inactive agents', async () => {
        const activeAgent: A2AAgent = {
          id: 'agent-1',
          organizationId: 'org-1',
          isActive: true,
        } as A2AAgent;

        const inactiveAgent: A2AAgent = {
          id: 'agent-2',
          organizationId: 'org-1',
          isActive: false,
        } as A2AAgent;

        service['agents'].set('agent-1', activeAgent);
        service['agents'].set('agent-2', inactiveAgent);

        const result = await service.listAgents('org-1');

        expect(result).toHaveLength(1);
        expect(result[0].id).toBe('agent-1');
      });
    });

    describe('updateAgent', () => {
      it('should update existing agent', async () => {
        const mockAgent: A2AAgent = {
          id: 'agent-1',
          name: 'Test Agent',
          organizationId: 'org-1',
          isActive: true,
          lastSeen: new Date('2023-01-01'),
        } as A2AAgent;

        service['agents'].set('agent-1', mockAgent);
        mockRedis.setex.mockResolvedValue('OK');

        const updates = { name: 'Updated Agent' };
        const result = await service.updateAgent('agent-1', updates);

        expect(result?.name).toBe('Updated Agent');
        expect(result?.lastSeen).not.toEqual(new Date('2023-01-01'));
        expect(mockRedis.setex).toHaveBeenCalled();
      });

      it('should return null for non-existent agent', async () => {
        mockRedis.get.mockResolvedValue(null);

        const result = await service.updateAgent('non-existent', {});

        expect(result).toBeNull();
      });
    });

    describe('deregisterAgent', () => {
      it('should deregister existing agent', async () => {
        const mockAgent: A2AAgent = {
          id: 'agent-1',
          name: 'Test Agent',
          organizationId: 'org-1',
          type: A2AAgentType.OPENAI,
          isActive: true,
        } as A2AAgent;

        service['agents'].set('agent-1', mockAgent);
        mockRedis.del.mockResolvedValue(1);

        const result = await service.deregisterAgent('agent-1');

        expect(result).toBe(true);
        expect(mockAgent.isActive).toBe(false);
        expect(mockRedis.del).toHaveBeenCalledWith('agent:agent-1');
      });

      it('should return false for non-existent agent', async () => {
        mockRedis.get.mockResolvedValue(null);

        const result = await service.deregisterAgent('non-existent');

        expect(result).toBe(false);
      });
    });
  });

  describe('Agent Communication', () => {
    const mockFromAgent: A2AAgent = {
      id: 'agent-1',
      organizationId: 'org-1',
      isActive: true,
    } as A2AAgent;

    const mockToAgent: A2AAgent = {
      id: 'agent-2',
      organizationId: 'org-1',
      isActive: true,
      endpoint: 'https://api.agent2.com',
      configuration: {
        timeout: 30000,
        headers: {},
      },
    } as A2AAgent;

    describe('sendMessage', () => {
      beforeEach(() => {
        service['agents'].set('agent-1', mockFromAgent);
        service['agents'].set('agent-2', mockToAgent);
        mockedAxios.mockResolvedValue({ status: 200, data: { response: 'success' } });
      });

      it('should send message between agents successfully', async () => {
        const content = { text: 'Hello from agent 1' };

        const result = await service.sendMessage('agent-1', 'agent-2', content);

        expect(result).toBeDefined();
        expect(result.fromAgentId).toBe('agent-1');
        expect(result.toAgentId).toBe('agent-2');
        expect(result.type).toBe(A2AMessageType.REQUEST);
        expect(result.content).toEqual(content);
      });

      it('should throw NotFoundException for missing from agent', async () => {
        await expect(
          service.sendMessage('non-existent', 'agent-2', {})
        ).rejects.toThrow(NotFoundException);
      });

      it('should throw NotFoundException for missing to agent', async () => {
        await expect(
          service.sendMessage('agent-1', 'non-existent', {})
        ).rejects.toThrow(NotFoundException);
      });

      it('should throw ForbiddenException for cross-organization communication', async () => {
        const otherOrgAgent: A2AAgent = {
          ...mockToAgent,
          organizationId: 'org-2',
        };
        service['agents'].set('agent-2', otherOrgAgent);

        await expect(
          service.sendMessage('agent-1', 'agent-2', {})
        ).rejects.toThrow(ForbiddenException);
      });

      it('should add message to queue', async () => {
        await service.sendMessage('agent-1', 'agent-2', { text: 'test' });

        const queue = service['messageQueue'].get('agent-2');
        expect(queue).toBeDefined();
        expect(queue?.length).toBe(1);
      });

      it('should support different message types', async () => {
        const result = await service.sendMessage(
          'agent-1',
          'agent-2',
          { response: 'data' },
          A2AMessageType.RESPONSE
        );

        expect(result.type).toBe(A2AMessageType.RESPONSE);
      });
    });

    describe('deliverMessage', () => {
      const mockMessage: A2AMessage = {
        id: 'msg-1',
        fromAgentId: 'agent-1',
        toAgentId: 'agent-2',
        type: A2AMessageType.REQUEST,
        content: { text: 'test message' },
        context: { organizationId: 'org-1' },
        metadata: { timestamp: new Date().toISOString() },
      };

      it('should deliver message successfully', async () => {
        service['agents'].set('agent-2', mockToAgent);
        mockedAxios.mockResolvedValue({ status: 200, data: { response: 'received' } });

        await service['deliverMessage'](mockMessage);

        expect(mockedAxios).toHaveBeenCalled();
        const axiosCall = mockedAxios.mock.calls[0][0] as any;
        expect(axiosCall.url).toBe('https://api.agent2.com');
        expect(axiosCall.method).toBe('POST');
        expect(axiosCall.data).toEqual(mockMessage);
      });

      it('should handle missing target agent', async () => {
        await service['deliverMessage'](mockMessage);

        // Should not throw, just log error
        expect(mockedAxios).not.toHaveBeenCalled();
      });

      it('should mark agent inactive on connection failure', async () => {
        service['agents'].set('agent-2', mockToAgent);
        mockedAxios.mockRejectedValue({ code: 'ECONNREFUSED' });

        await service['deliverMessage'](mockMessage);

        // Agent should be marked inactive due to connection failure
        // This would be tested by verifying updateAgent was called
      });

      it('should handle server errors appropriately', async () => {
        service['agents'].set('agent-2', mockToAgent);
        mockedAxios.mockRejectedValue({ response: { status: 500 } });

        await service['deliverMessage'](mockMessage);

        // Should handle 500 errors gracefully
        expect(mockedAxios).toHaveBeenCalled();
      });
    });

    describe('Protocol-specific request building', () => {
      it('should build OpenAI format requests', async () => {
        const mockAgent: A2AAgent = {
          ...mockToAgent,
          type: A2AAgentType.OPENAI,
        };

        const mockMessage: A2AMessage = {
          id: 'msg-1',
          fromAgentId: 'agent-1',
          toAgentId: 'agent-2',
          type: A2AMessageType.REQUEST,
          content: { text: 'test' },
          context: {
            organizationId: 'org-1',
            tools: ['function1', 'function2']
          },
        };

        const config = await service['buildAgentRequest'](mockAgent, mockMessage);

        expect(config.url).toBe('https://api.openai.com/v1/chat/completions');
        expect(config.data.model).toBe('gpt-4');
        expect(config.data.tools).toBeDefined();
        expect(config.data.tools).toHaveLength(2);
      });

      it('should build Anthropic format requests', async () => {
        const mockAgent: A2AAgent = {
          ...mockToAgent,
          type: A2AAgentType.ANTHROPIC,
        };

        const mockMessage: A2AMessage = {
          id: 'msg-1',
          fromAgentId: 'agent-1',
          toAgentId: 'agent-2',
          type: A2AMessageType.REQUEST,
          content: { text: 'test' },
          context: { organizationId: 'org-1' },
        };

        const config = await service['buildAgentRequest'](mockAgent, mockMessage);

        expect(config.url).toBe('https://api.anthropic.com/v1/messages');
        expect(config.headers['anthropic-version']).toBe('2023-06-01');
        expect(config.data.model).toBe('claude-3-sonnet-20240229');
      });

      it('should build custom LLM format requests', async () => {
        const mockAgent: A2AAgent = {
          ...mockToAgent,
          type: A2AAgentType.CUSTOM_LLM,
        };

        const mockMessage: A2AMessage = {
          id: 'msg-1',
          fromAgentId: 'agent-1',
          toAgentId: 'agent-2',
          type: A2AMessageType.REQUEST,
          content: { text: 'test' },
          context: { organizationId: 'org-1' },
        };

        const config = await service['buildAgentRequest'](mockAgent, mockMessage);

        expect(config.url).toBe(mockToAgent.endpoint);
        expect(config.data).toEqual(mockMessage);
      });
    });

    describe('Authentication', () => {
      let config: any;

      beforeEach(() => {
        config = {
          headers: {},
          params: {},
        };
      });

      it('should apply API key authentication in header', async () => {
        const auth = {
          type: 'api_key',
          config: { apiKey: 'test-key' },
          location: 'header',
          parameter: 'Authorization',
        };

        service['applyAuthentication'](config, auth);

        expect(config.headers['Authorization']).toBe('test-key');
      });

      it('should apply API key authentication in query', async () => {
        const auth = {
          type: 'api_key',
          config: { apiKey: 'test-key' },
          location: 'query',
          parameter: 'api_key',
        };

        service['applyAuthentication'](config, auth);

        expect(config.params['api_key']).toBe('test-key');
      });

      it('should apply Bearer token authentication', async () => {
        const auth = {
          type: 'bearer',
          config: { token: 'bearer-token' },
          location: 'header',
        };

        service['applyAuthentication'](config, auth);

        expect(config.headers['Authorization']).toBe('Bearer bearer-token');
      });

      it('should apply OAuth2 authentication', async () => {
        const auth = {
          type: 'oauth2',
          config: { accessToken: 'oauth-token' },
          location: 'header',
        };

        service['applyAuthentication'](config, auth);

        expect(config.headers['Authorization']).toBe('Bearer oauth-token');
      });
    });
  });

  describe('Session Management', () => {
    describe('createSession', () => {
      it('should create session successfully', async () => {
        const agent1: A2AAgent = { id: 'agent-1', organizationId: 'org-1' } as A2AAgent;
        const agent2: A2AAgent = { id: 'agent-2', organizationId: 'org-1' } as A2AAgent;

        service['agents'].set('agent-1', agent1);
        service['agents'].set('agent-2', agent2);
        mockRedis.setex.mockResolvedValue('OK');

        const result = await service.createSession('org-1', ['agent-1', 'agent-2'], { purpose: 'test' });

        expect(result).toBeDefined();
        expect(result.organizationId).toBe('org-1');
        expect(result.participantAgents).toEqual(['agent-1', 'agent-2']);
        expect(result.status).toBe(A2ASessionStatus.ACTIVE);
        expect(result.metadata?.purpose).toBe('test');
      });

      it('should throw BadRequestException for invalid agent', async () => {
        mockRedis.get.mockResolvedValue(null);

        await expect(
          service.createSession('org-1', ['non-existent'], {})
        ).rejects.toThrow(BadRequestException);
      });

      it('should throw BadRequestException for cross-organization agents', async () => {
        const agent1: A2AAgent = { id: 'agent-1', organizationId: 'org-1' } as A2AAgent;
        const agent2: A2AAgent = { id: 'agent-2', organizationId: 'org-2' } as A2AAgent;

        service['agents'].set('agent-1', agent1);
        service['agents'].set('agent-2', agent2);

        await expect(
          service.createSession('org-1', ['agent-1', 'agent-2'], {})
        ).rejects.toThrow(BadRequestException);
      });
    });

    describe('getSession', () => {
      const mockSession: A2ASession = {
        id: 'session-1',
        organizationId: 'org-1',
        participantAgents: ['agent-1', 'agent-2'],
        status: A2ASessionStatus.ACTIVE,
        startedAt: new Date(),
        lastActivity: new Date(),
        messageCount: 0,
      };

      it('should return session from memory cache', async () => {
        service['sessions'].set('session-1', mockSession);

        const result = await service.getSession('session-1');

        expect(result).toEqual(mockSession);
      });

      it('should return session from Redis cache', async () => {
        mockRedis.get.mockResolvedValue(JSON.stringify(mockSession));

        const result = await service.getSession('session-1');

        expect(result).toEqual(mockSession);
        expect(mockRedis.get).toHaveBeenCalledWith('session:session-1');
      });

      it('should return null for non-existent session', async () => {
        mockRedis.get.mockResolvedValue(null);

        const result = await service.getSession('non-existent');

        expect(result).toBeNull();
      });
    });
  });

  describe('Tool Registration', () => {
    const mockToolRegistration: A2AToolRegistration = {
      agentId: 'agent-1',
      toolName: 'testTool',
      description: 'A test tool',
      inputSchema: { type: 'object', properties: { input: { type: 'string' } } },
      outputSchema: { type: 'object', properties: { output: { type: 'string' } } },
      endpoint: '/tools/test',
      method: 'POST',
    };

    describe('registerAgentTool', () => {
      it('should register tool successfully', async () => {
        const mockAgent: A2AAgent = {
          id: 'agent-1',
          name: 'Test Agent',
          organizationId: 'org-1',
        } as A2AAgent;

        service['agents'].set('agent-1', mockAgent);

        await service.registerAgentTool('agent-1', mockToolRegistration);

        // Should complete without throwing
        expect(true).toBe(true);
      });

      it('should throw NotFoundException for invalid agent', async () => {
        mockRedis.get.mockResolvedValue(null);

        await expect(
          service.registerAgentTool('non-existent', mockToolRegistration)
        ).rejects.toThrow(NotFoundException);
      });
    });
  });

  describe('Agent Discovery and Health', () => {
    describe('discoverAgents', () => {
      it('should discover healthy agents', async () => {
        const agent1: A2AAgent = {
          id: 'agent-1',
          organizationId: 'org-1',
          isActive: true,
          endpoint: 'https://agent1.com',
          authentication: undefined,
        } as A2AAgent;

        service['agents'].set('agent-1', agent1);
        mockedAxios.mockResolvedValue({ status: 200 });

        const result = await service.discoverAgents('org-1');

        expect(result).toHaveLength(1);
        expect(result[0].id).toBe('agent-1');
      });

      it('should filter out unhealthy agents', async () => {
        const agent1: A2AAgent = {
          id: 'agent-1',
          organizationId: 'org-1',
          isActive: true,
          endpoint: 'https://agent1.com',
        } as A2AAgent;

        service['agents'].set('agent-1', agent1);
        mockedAxios.mockRejectedValue(new Error('Connection failed'));

        const result = await service.discoverAgents('org-1');

        expect(result).toHaveLength(0);
      });
    });

    describe('pingAgent', () => {
      it('should ping agent successfully', async () => {
        const mockAgent: A2AAgent = {
          endpoint: 'https://agent.com',
          authentication: undefined,
        } as A2AAgent;

        mockedAxios.mockResolvedValue({ status: 200 });

        await service['pingAgent'](mockAgent);

        expect(mockedAxios).toHaveBeenCalledWith({
          url: 'https://agent.com/health',
          method: 'GET',
          timeout: 5000,
        });
      });

      it('should apply authentication when pinging', async () => {
        const mockAgent: A2AAgent = {
          endpoint: 'https://agent.com',
          authentication: {
            type: 'bearer',
            config: { token: 'test-token' },
            location: 'header',
          },
        } as A2AAgent;

        mockedAxios.mockResolvedValue({ status: 200 });

        await service['pingAgent'](mockAgent);

        const axiosCall = mockedAxios.mock.calls[0][0] as any;
        expect(axiosCall.headers?.Authorization).toBe('Bearer test-token');
      });
    });

    describe('testAgentConnection', () => {
      it('should test connection successfully', async () => {
        mockedAxios.mockResolvedValue({ status: 200 });

        await service['testAgentConnection']('https://agent.com');

        expect(mockedAxios).toHaveBeenCalledWith({
          url: 'https://agent.com',
          method: 'GET',
          timeout: 10000,
        });
      });

      it('should throw BadRequestException for connection failure', async () => {
        mockedAxios.mockRejectedValue(new Error('Connection failed'));

        await expect(
          service['testAgentConnection']('https://agent.com')
        ).rejects.toThrow(BadRequestException);
      });
    });
  });

  describe('Orchestration', () => {
    describe('orchestrateAgents', () => {
      it('should create and execute workflow', async () => {
        const mockAgent: A2AAgent = {
          id: 'agent-1',
          organizationId: 'org-1',
          endpoint: 'https://agent1.com',
          configuration: { timeout: 30000, headers: {} },
        } as A2AAgent;

        service['agents'].set('agent-1', mockAgent);
        mockedAxios.mockResolvedValue({ status: 200, data: {} });

        const workflow = {
          name: 'Test Workflow',
          description: 'A test workflow',
          steps: [
            {
              agentId: 'agent-1',
              action: 'processData',
              parameters: { data: 'test' },
            },
          ],
        };

        const result = await service.orchestrateAgents('org-1', workflow);

        expect(result).toBeDefined();
        expect(typeof result).toBe('string');

        // Workflow should be stored
        const storedWorkflow = service['workflows'].get(result);
        expect(storedWorkflow).toBeDefined();
        expect(storedWorkflow?.name).toBe('Test Workflow');
      });

      it('should execute workflow steps', async () => {
        const mockAgent: A2AAgent = {
          id: 'agent-1',
          organizationId: 'org-1',
          endpoint: 'https://agent1.com',
          configuration: { timeout: 30000, headers: {} },
        } as A2AAgent;

        service['agents'].set('agent-1', mockAgent);
        mockedAxios.mockResolvedValue({ status: 200, data: {} });

        const workflow = {
          name: 'Test Workflow',
          steps: [
            {
              agentId: 'agent-1',
              action: 'step1',
              parameters: { input: 'test' },
            },
          ],
        };

        await service.orchestrateAgents('org-1', workflow);

        expect(mockedAxios).toHaveBeenCalled();
      });
    });
  });

  describe('Agent Clustering', () => {
    describe('createAgentCluster', () => {
      it('should create cluster successfully', async () => {
        mockRedis.setex.mockResolvedValue('OK');

        const clusterData = {
          name: 'Test Cluster',
          agentIds: ['agent-1', 'agent-2'],
          loadBalancing: 'round_robin' as const,
          fallback: true,
        };

        const result = await service.createAgentCluster('org-1', clusterData);

        expect(result).toBeDefined();
        expect(typeof result).toBe('string');
        expect(result.startsWith('cluster_')).toBe(true);
        expect(mockRedis.setex).toHaveBeenCalled();
      });
    });
  });

  describe('Metrics and Statistics', () => {
    describe('getAgentMetrics', () => {
      it('should return metrics from Redis', async () => {
        const mockMetrics: A2AMetrics = {
          agentId: 'agent-1',
          totalMessages: 100,
          successfulMessages: 95,
          failedMessages: 5,
          averageResponseTime: 250,
          lastActivity: new Date(),
          capabilities: {
            functionsUsed: ['func1', 'func2'],
            toolsUsed: ['tool1'],
            workflowsParticipated: ['workflow1'],
          },
          performance: {
            uptime: 99.5,
            errorRate: 0.05,
            throughput: 10.5,
          },
        };

        mockRedis.get.mockResolvedValue(JSON.stringify(mockMetrics));

        const result = await service.getAgentMetrics('agent-1');

        expect(result).toEqual(mockMetrics);
      });

      it('should return default metrics when none cached', async () => {
        mockRedis.get.mockResolvedValue(null);

        const result = await service.getAgentMetrics('agent-1');

        expect(result.agentId).toBe('agent-1');
        expect(result.totalMessages).toBe(0);
        expect(result.successfulMessages).toBe(0);
        expect(result.failedMessages).toBe(0);
      });

      it('should handle Redis errors', async () => {
        mockRedis.get.mockRejectedValue(new Error('Redis error'));

        const result = await service.getAgentMetrics('agent-1');

        expect(result.agentId).toBe('agent-1');
        expect(result.totalMessages).toBe(0);
      });
    });

    describe('getA2AStats', () => {
      it('should return comprehensive statistics', async () => {
        const agent1: A2AAgent = {
          id: 'agent-1',
          organizationId: 'org-1',
          isActive: true,
        } as A2AAgent;

        const session1: A2ASession = {
          id: 'session-1',
          organizationId: 'org-1',
          status: A2ASessionStatus.ACTIVE,
        } as A2ASession;

        service['agents'].set('agent-1', agent1);
        service['sessions'].set('session-1', session1);

        mockRedis.keys.mockResolvedValue(['messages:org-1:agent-1']);
        mockRedis.llen.mockResolvedValue(50);

        const result = await service.getA2AStats('org-1');

        expect(result.totalAgents).toBe(1);
        expect(result.activeAgents).toBe(1);
        expect(result.activeSessions).toBe(1);
        expect(result.totalMessages).toBe(50);
      });

      it('should handle Redis errors when getting message count', async () => {
        mockRedis.keys.mockRejectedValue(new Error('Redis error'));

        const result = await service.getA2AStats('org-1');

        expect(result.totalMessages).toBe(0);
      });
    });
  });

  describe('Event System', () => {
    describe('setupEventHandlers', () => {
      it('should set up message event handlers', async () => {
        mockRedis.setex.mockResolvedValue('OK');

        const mockMessage: A2AMessage = {
          id: 'msg-1',
          fromAgentId: 'agent-1',
          toAgentId: 'agent-2',
          type: A2AMessageType.REQUEST,
          content: {},
        } as A2AMessage;

        // Trigger messageReceived event
        service.emit('messageReceived', mockMessage);

        // Allow async operations to complete
        await new Promise(resolve => setTimeout(resolve, 10));

        expect(mockRedis.setex).toHaveBeenCalled();
      });
    });

    describe('emitA2AEvent', () => {
      it('should emit and store events', async () => {
        mockRedis.lpush.mockResolvedValue(1);
        mockRedis.ltrim.mockResolvedValue('OK');

        await service['emitA2AEvent']('agent_registered', {
          agentId: 'agent-1',
          organizationId: 'org-1',
          data: { name: 'Test Agent' },
        });

        expect(mockRedis.lpush).toHaveBeenCalledWith('a2a:events', expect.any(String));
        expect(mockRedis.ltrim).toHaveBeenCalledWith('a2a:events', 0, 1000);
      });
    });
  });

  describe('Cleanup and Shutdown', () => {
    describe('shutdown', () => {
      it('should deregister all agents', async () => {
        const agent1: A2AAgent = { id: 'agent-1' } as A2AAgent;
        const agent2: A2AAgent = { id: 'agent-2' } as A2AAgent;

        service['agents'].set('agent-1', agent1);
        service['agents'].set('agent-2', agent2);
        mockRedis.del.mockResolvedValue(1);

        await service.shutdown();

        expect(mockRedis.del).toHaveBeenCalledTimes(2);
        expect(agent1.isActive).toBe(false);
        expect(agent2.isActive).toBe(false);
      });
    });
  });

  describe('Edge Cases and Error Handling', () => {
    it('should handle malformed message responses', async () => {
      const mockMessage: A2AMessage = {
        id: 'msg-1',
        fromAgentId: 'agent-1',
        toAgentId: 'agent-2',
        type: A2AMessageType.REQUEST,
        content: { text: 'test' },
      } as A2AMessage;

      const malformedResponse = 'invalid json response';

      await service['handleAgentResponse'](mockMessage, malformedResponse);

      const queue = service['messageQueue'].get('agent-1');
      expect(queue).toBeDefined();
      expect(queue?.[0].content.data).toBe(malformedResponse);
    });

    it('should handle concurrent message delivery', async () => {
      const mockAgent: A2AAgent = {
        id: 'agent-1',
        endpoint: 'https://agent.com',
        configuration: { timeout: 30000, headers: {} },
      } as A2AAgent;

      service['agents'].set('agent-1', mockAgent);
      mockedAxios.mockResolvedValue({ status: 200, data: {} });

      const messages = Array.from({ length: 5 }, (_, i) => ({
        id: `msg-${i}`,
        fromAgentId: 'sender',
        toAgentId: 'agent-1',
        type: A2AMessageType.REQUEST,
        content: { text: `message ${i}` },
      } as A2AMessage));

      const deliveryPromises = messages.map(msg =>
        service['deliverMessage'](msg)
      );

      await Promise.all(deliveryPromises);

      expect(mockedAxios).toHaveBeenCalledTimes(5);
    });

    it('should handle very large message payloads', async () => {
      const largeContent = {
        data: Array.from({ length: 10000 }, (_, i) => ({
          id: i,
          value: `large-data-${i}`.repeat(100),
        })),
      };

      const agent1: A2AAgent = { id: 'agent-1', organizationId: 'org-1' } as A2AAgent;
      const agent2: A2AAgent = {
        id: 'agent-2',
        organizationId: 'org-1',
        endpoint: 'https://agent2.com',
        configuration: { timeout: 30000, headers: {} },
      } as A2AAgent;

      service['agents'].set('agent-1', agent1);
      service['agents'].set('agent-2', agent2);
      mockedAxios.mockResolvedValue({ status: 200, data: {} });

      const result = await service.sendMessage('agent-1', 'agent-2', largeContent);

      expect(result.content).toEqual(largeContent);
      expect(mockedAxios).toHaveBeenCalled();
    });
  });
});