{
  "name": "@almyty/mcp-mux",
  "version": "1.2.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Share one stdio MCP server subprocess across many concurrent clients over a Unix socket \u2014 remaps request ids, serializes writes, respawns on crash. Internal almyty plumbing.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "almyty",
    "mcp",
    "multiplexer",
    "stdio",
    "proxy"
  ],
  "author": "almyty",
  "license": "Apache-2.0",
  "homepage": "https://almyty.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/almyty-inc/almyty.git",
    "directory": "packages/mcp-mux"
  },
  "bugs": {
    "url": "https://github.com/almyty-inc/almyty/issues"
  }
}
