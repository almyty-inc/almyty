{
  "name": "@almyty/mcp-mux",
  "version": "1.2.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Southbound stdio-MCP id-rewrite multiplexer: fan N sessions into one downstream MCP child over a Unix socket.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "keywords": ["almyty", "mcp", "multiplexer", "stdio", "proxy"],
  "author": "almyty",
  "license": "Apache-2.0"
}
