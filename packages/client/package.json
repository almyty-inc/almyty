  },
  "keywords": [
    "almyty",
    "client",
    "sdk"
  ],
  "author": "almyty",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "homepage": "https://almyty.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/almyty-inc/almyty.git",
    "directory": "packages/client"
  },
  "bugs": {
    "url": "https://github.com/almyty-inc/almyty/issues"
  }
