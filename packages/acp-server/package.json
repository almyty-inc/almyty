{
  "name": "@almyty/acp-server",
  "version": "1.2.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Expose any almyty agent over the Agent Client Protocol (ACP) \u2014 drop your agent into ACP-compatible editors and clients.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "almyty-acp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "acp",
    "agent-client-protocol",
    "ai-agents",
    "almyty",
    "zed",
    "jetbrains"
  ],
  "author": "almyty",
  "license": "Apache-2.0",
  "dependencies": {
    "@almyty/client": "^1.2.0",
    "eventsource-parser": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "homepage": "https://almyty.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/almyty-inc/almyty.git",
    "directory": "packages/acp-server"
  },
  "bugs": {
    "url": "https://github.com/almyty-inc/almyty/issues"
  }
}
