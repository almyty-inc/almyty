{
  "name": "@almyty/mcp-server",
  "version": "1.2.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Serve any almyty gateway to Claude Code or any MCP client \u2014 turn your APIs into MCP tools with a single command.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "almyty-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-tools",
    "api-gateway",
    "openapi",
    "graphql",
    "almyty",
    "claude",
    "cursor",
    "copilot",
    "codex"
  ],
  "author": "almyty",
  "license": "Apache-2.0",
  "dependencies": {
    "@almyty/client": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.7.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3"
  },
  "homepage": "https://almyty.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/almyty-inc/almyty.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/almyty-inc/almyty/issues"
