{
  "name": "@almyty/agents",
  "version": "1.2.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Run and manage almyty agents from your terminal \u2014 list, invoke workflow or autonomous runs, stream steps, and inspect run history.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "almyty-agents": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "almyty",
    "agents",
    "cli"
  ],
  "author": "almyty",
  "license": "Apache-2.0",
  "dependencies": {
    "@almyty/client": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "homepage": "https://almyty.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/almyty-inc/almyty.git",
    "directory": "packages/agents-cli"
  },
  "bugs": {
    "url": "https://github.com/almyty-inc/almyty/issues"
  }
}
