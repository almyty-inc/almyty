{
  "name": "@almyty/agents",
  "version": "0.1.3",
  "description": "List, run, and manage almyty agents from the command line",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "almyty-agents": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "almyty",
    "agents",
    "cli"
  ],
  "author": "almyty",
  "license": "BSL-1.1",
  "dependencies": {
    "@almyty/client": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  }
}
