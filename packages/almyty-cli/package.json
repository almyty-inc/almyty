{
  "name": "@almyty/cli",
  "version": "1.2.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "The almyty CLI \u2014 one login for agents, chat, skills, an MCP server, and a machine runner. Part of almyty, the full-stack platform for AI agents.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "almyty": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "almyty",
    "cli",
    "agents",
    "chat",
    "skills",
    "mcp"
  ],
  "author": "almyty",
  "license": "Apache-2.0",
  "dependencies": {
    "@almyty/auth": "^1.2.0",
    "@almyty/agents": "^1.2.0",
    "@almyty/chat": "^1.2.0",
    "@almyty/skills": "^1.2.0",
    "@almyty/mcp-server": "^1.2.0",
    "@almyty/acp-server": "^1.2.0",
    "@almyty/runner": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "homepage": "https://almyty.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/almyty-inc/almyty.git",
    "directory": "packages/almyty-cli"
  },
  "bugs": {
    "url": "https://github.com/almyty-inc/almyty/issues"
  }
}
