{
  "name": "@almyty/chat",
  "version": "1.2.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Chat with your almyty agents in an interactive terminal REPL \u2014 multi-turn and streaming, with tool calls and autonomous runs.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "almyty-chat": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "almyty",
    "agents",
    "chat",
    "repl",
    "cli"
  ],
  "author": "almyty",
  "license": "Apache-2.0",
  "dependencies": {
    "@almyty/client": "^1.2.0",
    "@types/react": "^19.2.14",
    "ink": "^7.0.1",
    "ink-spinner": "^5.0.0",
    "ink-testing-library": "^4.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "homepage": "https://almyty.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/almyty-inc/almyty.git",
    "directory": "packages/chat-cli"
  },
