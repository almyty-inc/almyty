{
  "name": "@almyty/chat",
  "version": "0.1.1",
  "description": "Interactive chat REPL with almyty agents",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "almyty-chat": "dist/index.js"
  },
  "files": [
    "dist"
